rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserProfile() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function hasRole(role) {
      return isSignedIn() && currentUserProfile() != null && currentUserProfile().role == role;
    }

    function isAdmin() {
      return hasRole("admin");
    }

    function isRestaurantUser() {
      return hasRole("restaurant");
    }

    function isOwnUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnRestaurantDocument(restaurantId) {
      return isRestaurantUser() && currentUserProfile().restaurantId == restaurantId;
    }

    function canReadRestaurantDoc() {
      return isAdmin()
        || (isRestaurantUser() && resource != null && currentUserProfile().restaurantId == resource.data.id);
    }

    function canWriteRestaurantDoc() {
      return isAdmin()
        || (isRestaurantUser()
          && resource != null
          && request.resource != null
          && currentUserProfile().restaurantId == resource.data.id
          && request.resource.data.id == resource.data.id
          && request.resource.data.authUid == resource.data.authUid
          && request.resource.data.email == resource.data.email
          && request.resource.data.username == resource.data.username
          && request.resource.data.activatedAt == resource.data.activatedAt
          && request.resource.data.activatedUntil == resource.data.activatedUntil
          && request.resource.data.planName == resource.data.planName);
    }

    function canReadOrderDoc() {
      return isAdmin()
        || (isRestaurantUser()
          && resource != null
          && currentUserProfile().restaurantId == resource.data.restaurantId);
    }

    function canWriteOrderDoc() {
      return isAdmin()
        || (isRestaurantUser()
          && request.resource != null
          && currentUserProfile().restaurantId == request.resource.data.restaurantId
          && (
            resource == null
            || resource.data.restaurantId == currentUserProfile().restaurantId
          ));
    }

    function canManageTrackingDoc() {
      return isAdmin()
        || (isRestaurantUser()
          && request.resource != null
          && currentUserProfile().restaurantId == request.resource.data.restaurantId
          && (
            resource == null
            || resource.data.restaurantId == currentUserProfile().restaurantId
          ));
    }

    function isPublicTrackingRatingUpdate() {
      return request.auth == null
        && resource != null
        && resource.data.status == "delivered"
        && request.resource.data.keys().hasOnly([
          "id",
          "restaurantId",
          "publicTrackingToken",
          "sourceOrderId",
          "orderNumber",
          "customerName",
          "pickupPoint",
          "estimatedReadyMinutes",
          "promisedReadyAt",
          "status",
          "rating",
          "createdAt",
          "archivedAt",
        ])
        && request.resource.data.id == resource.data.id
        && request.resource.data.restaurantId == resource.data.restaurantId
        && request.resource.data.publicTrackingToken == resource.data.publicTrackingToken
        && request.resource.data.sourceOrderId == resource.data.sourceOrderId
        && request.resource.data.orderNumber == resource.data.orderNumber
        && request.resource.data.customerName == resource.data.customerName
        && request.resource.data.pickupPoint == resource.data.pickupPoint
        && request.resource.data.estimatedReadyMinutes == resource.data.estimatedReadyMinutes
        && request.resource.data.promisedReadyAt == resource.data.promisedReadyAt
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.archivedAt == resource.data.archivedAt
        && request.resource.data.rating is map
        && request.resource.data.rating.keys().hasOnly(["score", "comment", "createdAt"])
        && request.resource.data.rating.score is int
        && request.resource.data.rating.score >= 1
        && request.resource.data.rating.score <= 5
        && request.resource.data.rating.comment is string
        && request.resource.data.rating.comment.size() <= 160
        && request.resource.data.rating.createdAt is string
        && (
          !resource.data.keys().hasAny(["rating"])
          || resource.data.rating == null
          || (
            resource.data.rating is map
            && resource.data.rating.score == request.resource.data.rating.score
            && resource.data.rating.comment == request.resource.data.rating.comment
            && resource.data.rating.createdAt == request.resource.data.rating.createdAt
          )
        );
    }

    match /users/{userId} {
      allow read: if isOwnUser(userId) || isAdmin();
      allow write: if false;
    }

    match /orders/{orderId} {
      allow read: if canReadOrderDoc();
      allow create, update: if canWriteOrderDoc();
      allow delete: if isAdmin() || isOwnRestaurantDocument(resource.data.restaurantId);
    }

    match /restaurants/{restaurantId} {
      allow read: if canReadRestaurantDoc();
      allow create: if isAdmin();
      allow update: if canWriteRestaurantDoc();
      allow delete: if isAdmin();
    }

    match /tracking/{trackingId} {
      allow read: if true;
      allow create, update: if canManageTrackingDoc();
      allow delete: if isAdmin()
        || (isRestaurantUser()
          && resource != null
          && currentUserProfile().restaurantId == resource.data.restaurantId);
      allow update: if isPublicTrackingRatingUpdate();
    }
  }
}
